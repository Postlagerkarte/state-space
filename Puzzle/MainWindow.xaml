<Window x:Class="Puzzle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow"
        Width="525"
        Height="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Viewbox Stretch="Uniform">  
        <Grid x:Name="gameBoard" AllowDrop="False"
              ShowGridLines="False" >
            <Grid.Background>
                <ImageBrush Stretch="Fill" ImageSource="Images/GroundGravel_Grass.png" AlignmentY="Top" AlignmentX="Center"/>
            </Grid.Background>
            </Grid>
        </Viewbox>
        <StackPanel Grid.Row="1">
        <Button Click="Button_Click">Next</Button>
        <Button Click="Button_ClickSolve">Solve</Button>
        <Button Click="Button_ClickShowSolution">Show Solution</Button>
        </StackPanel>
    </Grid>
</Window>
