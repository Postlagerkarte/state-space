<Window x:Class="Puzzle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow"
        Width="525"
        Height="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Viewbox Stretch="Uniform">  
        <Grid x:Name="gameBoard" AllowDrop="False"
              ShowGridLines="False" >
            <Grid.Background>
                <ImageBrush Stretch="Fill" ImageSource="Images/Sand.jpg" AlignmentY="Top" AlignmentX="Center"/>
            </Grid.Background>
            </Grid>
        </Viewbox>  
        <Button Grid.Row="1" Click="Button_Click">Next</Button>
    </Grid>
</Window>
